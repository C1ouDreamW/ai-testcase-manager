# LLM 配置（OpenAI 兼容接口）
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash

# 未配置 API Key 时使用 mock 模式（返回示例数据）
LLM_MOCK_MODE=true

# 评测专用 LLM（AI Judge / 召回率判定），留空则复用上面的生成模型配置
EVAL_LLM_API_KEY=
EVAL_LLM_BASE_URL=
EVAL_LLM_MODEL=

# Embedding 模型（知识库检索），不配置则知识库功能不可用
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=

# 数据库（默认 SQLite，生产可改为 PostgreSQL）
DATABASE_URL=sqlite:///./data/app.db

# 后端
BACKEND_PORT=8000
DEBUG=true

# 前端跨域
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
